{
  "name": "lumasweep",
  "version": "1.4.1",
  "description": "macOS System Cleaner & Optimizer",
  "author": "Gbenga Orenuga",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir -c.mac.identity=null",
    "dist": "node scripts/release-macos.js",
    "dist:unsigned": "electron-builder --mac -c.mac.identity=null",
    "dist:x64": "electron-builder --mac dmg --x64 -c.forceCodeSigning=true",
    "dist:arm64": "electron-builder --mac dmg --arm64 -c.forceCodeSigning=true"
  },
  "build": {
    "appId": "com.lumasweep.app",
    "productName": "LumaSweep",
    "copyright": "Copyright © 2026 LumaSweep",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSAppleEventsUsageDescription": "LumaSweep uses Apple Events to reveal files, manage login items, and run macOS cleanup actions on your behalf."
      }
    },
    "dmg": {
      "title": "LumaSweep Installer",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  }
}
